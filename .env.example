# Mamoyo Services — Environment Configuration
# Copy this to .env.local and fill in your values.

# Site URL (used for sitemap, OG tags, canonical)
NEXT_PUBLIC_SITE_URL=https://mamoyomaids.com

# Business phone number (displayed on contact page, used for tel: links)
NEXT_PUBLIC_BUSINESS_PHONE=+263783717844

# Business WhatsApp number (used for wa.me links)
NEXT_PUBLIC_BUSINESS_WHATSAPP=+263783717844

# Secondary business phone number (alternative contact)
NEXT_PUBLIC_BUSINESS_PHONE_SECONDARY=+263716453381

# Business email address
NEXT_PUBLIC_BUSINESS_EMAIL=info@mamoyomaids.com

# Business physical address
NEXT_PUBLIC_BUSINESS_ADDRESS=Harare, Zimbabwe
