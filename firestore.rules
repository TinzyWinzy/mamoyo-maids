rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /leads/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'type', 'createdAt', 'status'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() > 0
                    && request.resource.data.type in ['contact', 'booking', 'staff-request', 'maid-request']
                    && request.resource.data.createdAt is string
                    && request.resource.data.status == 'new';
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.clientUid
      );
      allow read, update, delete: if request.auth != null && request.auth.token.isAdmin == true;
    }

    match /candidates/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'uid'])
                    && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth.uid == resource.data.uid;
      allow read: if request.auth.token.isAdmin == true;
      allow update: if request.auth.uid == resource.data.uid;
      allow update, delete: if request.auth.token.isAdmin == true;
    }

    match /maids/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.isAdmin == true;
    }
  }
}
